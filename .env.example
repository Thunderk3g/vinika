# Copy to .env.local and fill in. .env.local is git-ignored.

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Postgres — DIRECT connection (:5432) for drizzle-kit + migrations.
DATABASE_URL=
# Postgres — TRANSACTION POOLER (:6543) for the Next.js runtime (prepare:false).
POOL_DATABASE_URL=

# ── Grok (xAI) — server-only. Needs credits at console.x.ai to respond. ──
XAI_API_KEY=
XAI_MODEL=grok-3
XAI_BASE_URL=https://api.x.ai/v1

# ── SMTP for booking emails (nodemailer no-ops gracefully until set) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Vinika" <hello@vinika.com>
BOOKINGS_NOTIFY_EMAIL=hello@vinika.com

# ── Admin allowlist — ONLY these emails can access /admin (comma-separated). ──
# Authentication alone is NOT enough; an empty allowlist authorizes nobody.
ADMIN_EMAILS=
